// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum MeasurementStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

model SystemLog {
  id          Int      @id @default(autoincrement())
  user        User?    @relation(fields: [userId], references: [id])
  userId      Int?
  ipAddress   String
  device      String
  action      String
  method      String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           Int     @id @default(autoincrement())
  fullname     String
  email        String  @unique
  password     String
  profileImage String?
  role         Role    @default(USER)
  deviceId     String? @unique

  logins        SystemLog[]
  measurements  Measurement[]
  notifications Notification[]
  device        Device?        @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id           String       @id @default(uuid())
  deviceNumber String       @unique
  status       DeviceStatus @default(OFFLINE)
  lastSeen     DateTime?
  batteryLevel Int?

  user         User?
  measurements Measurement[]
  ppgResults   PpgResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Measurement {
  id          Int               @id @default(autoincrement())
  userId      Int
  deviceId    String
  status      MeasurementStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  completedAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ppgResult PpgResult?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resultClass     Int?
  resultLabel     String?
  confidenceLevel Float?

  @@index([userId])
  @@index([deviceId])
}

model PpgResult {
  id            Int      @id @default(autoincrement())
  measurementId Int      @unique
  deviceId      String
  rawPpgData    Json // Store array of PPG values
  measuredAt    DateTime @default(now())

  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)
  device      Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([measurementId])
  @@index([deviceId])
}

enum NotificationType {
  AF_DETECTED
  SYSTEM_INFO
}

model Notification {
  id      Int              @id @default(autoincrement())
  userId  Int
  title   String
  message String           @db.Text
  type    NotificationType @default(SYSTEM_INFO)
  isRead  Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
